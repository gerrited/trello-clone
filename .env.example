# Copy to .env and fill in values

# Database
DATABASE_URL=postgres://trello:trello_secret@localhost:5432/trello_clone

# JWT
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-string-at-least-32-chars

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# App
API_PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:5173

# File Storage
# STORAGE_BACKEND: "local" (default) stores files on disk; "s3" uses S3-compatible object storage
STORAGE_BACKEND=local

# S3-compatible storage (required when STORAGE_BACKEND=s3)
# Works with AWS S3, Cloudflare R2, MinIO, and other S3-compatible providers
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public base URL for files — may differ from endpoint (e.g. CDN or R2 custom domain)
S3_PUBLIC_URL=
